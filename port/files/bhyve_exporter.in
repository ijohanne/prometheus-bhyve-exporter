#!/bin/sh

# PROVIDE: bhyve_exporter
# REQUIRE: LOGIN
# KEYWORD: shutdown

. /etc/rc.subr

name="bhyve_exporter"
rcvar="${name}_enable"

: ${bhyve_exporter_enable:="NO"}
: ${bhyve_exporter_listen_address:="0.0.0.0:9288"}
: ${bhyve_exporter_vm_command:="/usr/local/sbin/vm"}

pidfile="/var/run/${name}.pid"
command="/usr/local/bin/prometheus-bhyve-exporter"
command_args="--listen-address ${bhyve_exporter_listen_address} --vm-command ${bhyve_exporter_vm_command}"

start_cmd="${name}_start"

bhyve_exporter_start()
{
	echo "Starting ${name}."
	/usr/sbin/daemon -f -p ${pidfile} -t ${name} \
		${command} ${command_args}
}

load_rc_config $name
run_rc_command "$1"
